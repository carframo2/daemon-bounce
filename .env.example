# --- Auth (opcional; si vacío, endpoints abiertos) ---
DAEMON_TOKEN=pon_aqui_un_token

# --- Estado persistente local ---
STATE_FILE=/tmp/daemon_bounce_state.json

# --- Notion watch ---
NOTION_TOKEN=secret_xxx
NOTION_API_VERSION=2022-06-28
NOTION_WATCH_PAGE_TITLE=test_bridge
# NOTION_WATCH_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_MAX_BLOCKS=500
NOTION_TIMEOUT_SEC=15

# --- Bounce/forward ---
BOUNCE_TIMEOUT_SEC=20
BOUNCE_MAX_HOPS=1
TICK_COOLDOWN_SEC=2

# --- Warmup opcional (Groq u otro) ---
# Ejemplo: una llamada tonta al bridge para mantener Groq "caliente"
# GROQ_WARMUP_URL=https://tu-bridge.onrender.com/api/message?text=ping&model=openai/gpt-oss-120b&token=TU_TOKEN
GROQ_WARMUP_COOLDOWN_SEC=1500
